# Check keycodes: `skhd -o` (`ctrl + c` to stop)
# "[": 0x21
# "]": 0x1E
# "-": 0x1B
# "+": 0x18
# "\": 0x2A


# focus space
ctrl - left      : yabai -m space --focus prev
ctrl - right     : yabai -m space --focus next
ctrl - backspace : yabai -m space --focus recent
ctrl - 1         : yabai -m space --focus 1
ctrl - 2         : yabai -m space --focus 2
ctrl - 3         : yabai -m space --focus 3
ctrl - 4         : yabai -m space --focus 4
ctrl - 5         : yabai -m space --focus 5
ctrl - 6         : yabai -m space --focus 6
ctrl - 7         : yabai -m space --focus 7
ctrl - 8         : yabai -m space --focus 8
ctrl - 9         : yabai -m space --focus 9
ctrl - 0         : yabai -m space --focus 10

# focus window
lctrl + lshift - 0x1B   : yabai -m window --focus prev
lctrl + lshift - 0x18   : yabai -m window --focus next
lctrl + lshift - return : yabai -m window --focus recent
lctrl + lshift - h      : yabai -m window --focus west
lctrl + lshift - j      : yabai -m window --focus south
lctrl + lshift - k      : yabai -m window --focus north
lctrl + lshift - l      : yabai -m window --focus east
lctrl + lshift - 0x21   : yabai -m window --focus stack.prev
lctrl + lshift - 0x1E   : yabai -m window --focus stack.next
lctrl + lshift - 0x2A   : yabai -m window --focus stack.recent

# warp window
lctrl + lcmd - 0x21 : yabai -m window --warp prev
lctrl + lcmd - 0x1E : yabai -m window --warp next
lctrl + lcmd - h    : yabai -m window --warp west
lctrl + lcmd - j    : yabai -m window --warp south
lctrl + lcmd - k    : yabai -m window --warp north
lctrl + lcmd - l    : yabai -m window --warp east

# swap window
lctrl + lalt - 0x21 : yabai -m window --swap prev
lctrl + lalt - 0x1E : yabai -m window --swap next
lctrl + lalt - 0x2A : yabai -m window --swap recent
lctrl + lalt - h    : yabai -m window --swap west
lctrl + lalt - j    : yabai -m window --swap south
lctrl + lalt - k    : yabai -m window --swap north
lctrl + lalt - l    : yabai -m window --swap east

# stack window
lctrl + lcmd + lshift - 0x21 : win_id=$(yabai -m query --windows --window | jq '.id') && \
                               yabai -m window --stack prev && \
                               yabai -m window --focus "$win_id" --layer below
lctrl + lcmd + lshift - 0x1E : win_id=$(yabai -m query --windows --window | jq '.id') && \
                               yabai -m window --stack next && \
                               yabai -m window --focus "$win_id" --layer below
lctrl + lcmd + lshift - 0x2A : yabai -m window --focus recent && \
                               yabai -m window --stack recent && \
                               yabai -m window --focus stack.last --layer below
lctrl + lcmd + lshift - h    : yabai -m window --focus west && \
                               yabai -m window --stack east && \
                               yabai -m window --focus stack.last --layer below
lctrl + lcmd + lshift - j    : yabai -m window --focus south && \
                               yabai -m window --stack north && \
                               yabai -m window --focus stack.last --layer below
lctrl + lcmd + lshift - k    : yabai -m window --focus north && \
                               yabai -m window --stack south && \
                               yabai -m window --focus stack.last --layer below
lctrl + lcmd + lshift - l    : yabai -m window --focus east && \
                               yabai -m window --stack west && \
                               yabai -m window --focus stack.last --layer below

# set layer
lctrl + lcmd - d : yabai -m window --layer above
lctrl + lcmd - s : yabai -m window --layer normal
lctrl + lcmd - a : yabai -m window --layer below
lctrl + lcmd + lshift - a : $HOME/.config/yabai/layer-below-all.sh

# Set insert
lctrl + lcmd + lshift - return : yabai -m window --insert stack
lctrl + lcmd + lshift - left   : yabai -m window --insert west
lctrl + lcmd + lshift - down   : yabai -m window --insert south
lctrl + lcmd + lshift - up     : yabai -m window --insert north
lctrl + lcmd + lshift - right  : yabai -m window --insert east

# focus display
rctrl + rcmd - 0x21 : yabai -m display --focus prev
rctrl + rcmd - 0x1E : yabai -m display --focus next
rctrl + rcmd - 1    : yabai -m display --focus 1
rctrl + rcmd - 2    : yabai -m display --focus 2
rctrl + rcmd - 3    : yabai -m display --focus 3

# move window to space
lctrl + cmd - 1 : yabai -m window --space 1
lctrl + cmd - 2 : yabai -m window --space 2
lctrl + cmd - 3 : yabai -m window --space 3
lctrl + cmd - 4 : yabai -m window --space 4
lctrl + cmd - 5 : yabai -m window --space 5
lctrl + cmd - 6 : yabai -m window --space 6
lctrl + cmd - 7 : yabai -m window --space 7
lctrl + cmd - 8 : yabai -m window --space 8
lctrl + cmd - 9 : yabai -m window --space 9
lctrl + cmd - 0 : yabai -m window --space 10

# move window to space and follow focus
rctrl + rshift - 0x21 : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space prev && \
                        yabai -m space --focus prev && \
                        yabai -m window --focus $win_id
rctrl + rshift - 0x1E : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space next && \
                        yabai -m space --focus next && \
                        yabai -m window --focus $win_id
rctrl + rshift - 1    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 1 && \
                        yabai -m space --focus 1 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 2    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 2 && \
                        yabai -m space --focus 2 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 3    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 3 && \
                        yabai -m space --focus 3 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 4    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 4 && \
                        yabai -m space --focus 4 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 5    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 5 && \
                        yabai -m space --focus 5 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 6    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 6 && \
                        yabai -m space --focus 6 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 7    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 7 && \
                        yabai -m space --focus 7 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 8    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 8 && \
                        yabai -m space --focus 8 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 9    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 9 && \
                        yabai -m space --focus 9 && \
                        yabai -m window --focus $win_id
rctrl + rshift - 0    : win_id=$(yabai -m query --windows --window | jq '.id') && \
                        yabai -m window --space 10 && \
                        yabai -m space --focus 10 && \
                        yabai -m window --focus $win_id

# move window to display
lctrl + rcmd + rshift - 1 : yabai -m window --display 1
lctrl + rcmd + rshift - 2 : yabai -m window --display 2
lctrl + rcmd + rshift - 3 : yabai -m window --display 3

# move window to display and follow focus
rcmd + rshift - 1 : win_id=$(yabai -m query --windows --window | jq '.id') && \
                    yabai -m window --display 1 && \
                    yabai -m display --focus 1 && \
                    yabai -m window --focus $win_id
rcmd + rshift - 2 : win_id=$(yabai -m query --windows --window | jq '.id') && \
                    yabai -m window --display 2 && \
                    yabai -m display --focus 2 && \
                    yabai -m window --focus $win_id
rcmd + rshift - 3 : win_id=$(yabai -m query --windows --window | jq '.id') && \
                    yabai -m window --display 3 && \
                    yabai -m display --focus 3 && \
                    yabai -m window --focus $win_id
lctrl + lcmd + lshift - 1 : $HOME/.config/yabai/toggle-float.sh && \
                            yabai -m window --display 1 && \
                            yabai -m display --focus 1
lctrl + lcmd + lshift - 2 : $HOME/.config/yabai/toggle-float.sh && \
                            yabai -m window --display 2 && \
                            yabai -m display --focus 2
lctrl + lcmd + lshift - 3 : $HOME/.config/yabai/toggle-float.sh && \
                            yabai -m window --display 3 && \
                            yabai -m display --focus 3

# window zoom
lctrl + lalt - s : yabai -m window --toggle zoom-parent
lctrl + lalt - d : yabai -m window --toggle zoom-fullscreen
lctrl + lalt - f : yabai -m window --toggle native-fullscreen

# resize float
lctrl + lalt + lcmd - h : yabai -m window --resize left:-20:0               # + left
lctrl + lalt + lcmd - j : yabai -m window --resize bottom:0:20              # + bottom
lctrl + lalt + lcmd - k : yabai -m window --resize top:0:-20                # + top
lctrl + lalt + lcmd - l : yabai -m window --resize right:20:0               # + right
lctrl + lalt + lcmd + rshift - h : yabai -m window --resize left:-1:0       # + left micro
lctrl + lalt + lcmd + rshift - j : yabai -m window --resize bottom:0:1      # + bottom micro
lctrl + lalt + lcmd + rshift - k : yabai -m window --resize top:0:-1        # + top micro
lctrl + lalt + lcmd + rshift - l : yabai -m window --resize right:1:0       # + right micro
lalt + lcmd + lshift - h : yabai -m window --resize left:20:0               # - left
lalt + lcmd + lshift - j : yabai -m window --resize bottom:0:-20            # - bottom
lalt + lcmd + lshift - k : yabai -m window --resize top:0:20                # - top
lalt + lcmd + lshift - l : yabai -m window --resize right:-20:0             # - right
lalt + lcmd + lshift + rshift - h : yabai -m window --resize left:1:0       # - left micro
lalt + lcmd + lshift + rshift - j : yabai -m window --resize bottom:0:-1    # - bottom micro
lalt + lcmd + lshift + rshift - k : yabai -m window --resize top:0:1        # - top micro
lalt + lcmd + lshift + rshift - l : yabai -m window --resize right:-1:0     # - right micro
lctrl + lalt + lcmd - 0x18 : yabai -m window --resize bottom_right:20:20    # + diagonal
lctrl + lalt + lcmd - 0x1B : yabai -m window --resize bottom_right:-20:-20  # - diagonal

# move float
lctrl + lalt + lshift - h : yabai -m window --move rel:-20:0            # move left
lctrl + lalt + lshift - j : yabai -m window --move rel:0:20             # move down
lctrl + lalt + lshift - k : yabai -m window --move rel:0:-20            # move up
lctrl + lalt + lshift - l : yabai -m window --move rel:20:0             # move right
lctrl + lalt + lshift + rshift - h : yabai -m window --move rel:-1:0    # move left micro
lctrl + lalt + lshift + rshift - j : yabai -m window --move rel:0:1     # move down micro
lctrl + lalt + lshift + rshift - k : yabai -m window --move rel:0:-1    # move up micro
lctrl + lalt + lshift + rshift - l : yabai -m window --move rel:1:0     # move right micro

# window actions
lctrl + lalt - c : $HOME/.config/yabai/float-center.sh
lctrl + lcmd + lshift - q : yabai -m window --ratio abs:0.333
lctrl + lcmd + lshift - w : yabai -m window --ratio abs:0.5
lctrl + lcmd + lshift - e : yabai -m window --ratio abs:0.666
lctrl + lcmd + lshift - s : yabai -m window --toggle split
lctrl + lshift + rshift - s : yabai -m window --toggle sticky
lctrl + lshift + rshift - p : yabai -m window --toggle sticky --toggle topmost --toggle pip

# window tree actions
lctrl + lshift + rshift - b    : yabai -m space --balance
lctrl + lshift + rshift - x    : yabai -m space --mirror x-axis
lctrl + lshift + rshift - y    : yabai -m space --mirror y-axis
lctrl + lshift + rshift - 0x1E : yabai -m space --rotate 270    # cycle clockwise
lctrl + lshift + rshift - 0x21 : yabai -m space --rotate 90     # cycle counter-clockwise
lctrl + lcmd + lshift + rshift - p : yabai -m space --toggle padding && yabai -m space --toggle gap  # toggle padding and gap

# Layout management
lctrl + lshift + rshift - 0x2A      : yabai -m space --layout float
lctrl + lshift + rshift - backspace : yabai -m space --layout bsp

# create/destroy space
rctrl + rcmd + rshift - n : space_idx=$(($(yabai -m query --spaces --space | jq '.index') + 1)) && \
                            yabai -m space --create && \
                            new_idx=$(yabai -m query --spaces --display | jq 'map(select(."is-native-fullscreen" == false))[-1].index') && \
                            yabai -m space --focus "$new_idx" && \
                            yabai -m space --move "$space_idx"
rctrl + rcmd + rshift - d : idx=$(yabai -m query --spaces --space | jq '.index') && \
                            yabai -m space --focus recent \
                            yabai -m space --destroy "$idx"

.load "partial_ultrawide"
# .load "partial_mbp"
