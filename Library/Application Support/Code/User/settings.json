{
  "workbench.iconTheme": "eq-material-theme-icons",
  "workbench.list.automaticKeyboardNavigation": false,
  "editor.fontFamily": "JetBrainsMono Nerd Font, SauceCodePro Nerd Font, Rec Mono Custom Linear, SF Mono, RobotoMono Nerd Font, Operator Mono Lig, Operator Mono, Menlo, Monaco, Fira Code, sans serif",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.useTabStops": true,
  "editor.cursorSurroundingLines": 10,
  "editor.lineNumbers": "relative",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "explorer.compactFolders": false,
  "files.trimTrailingWhitespace": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "terminal.external.osxExec": "iTerm.app",
  "window.newWindowDimensions": "offset",
  "workbench.startupEditor": "none",

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "typescript.suggest.includeCompletionsWithSnippetText": false,
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": false,
    "editor.tabSize": 4
  },
  "go.toolsManagement.autoUpdate": true,
  "python.defaultInterpreterPath": "/Users/dav/.pyenv/versions/3.9.6/bin/python",
  "[python]": {
    "editor.defaultFormatter": null,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.useTabStops": true,
    "gitlens.codeLens.symbolScopes": ["!Module"]
  },
  "python.formatting.provider": "black",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },

  "prettier.singleQuote": true,
  "prettier.arrowParens": "avoid",
  "relativePath.excludedExtensions": [".js", ".jsx", ".ts", ".tsx"],
  "turboConsoleLog.quote": "'",
  "turboConsoleLog.logMessagePrefix": "",
  "turboConsoleLog.insertEnclosingFunction": false,
  "turboConsoleLog.includeFileNameAndLineNum": false,
  "turboConsoleLog.insertEnclosingClass": false,
  "liveServer.settings.donotShowInfoMsg": true,

  "vim.leader": ",",
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.easymotion": true,
  "vim.handleKeys": {
    "<C-w>": false
  },
  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "w", "r"],
      "commands": ["workbench.action.files.save"],
      "silent": true
    },
    {
      "before": ["<leader>", "w", "a"],
      "commands": ["workbench.action.files.saveFiles"],
      "silent": true
    },
    {
      "before": ["<leader>", "f", "m"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "l", "l"],
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.view.explorer"]
      // "commands": ["workbench.view.explorer", "workbench.action.focusSideBar"]
    },
    {
      "before": ["<leader>", "b"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    {
      "before": ["g", "t"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["g", "T"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["<leader>", "t", "m"],
      "commands": ["editor.action.toggleMinimap"]
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "t", "t"],
      "commands": ["terminal.focus"]
    },
    {
      "before": ["<leader>", "t", "n"],
      "commands": ["workbench.action.terminal.new"]
    },
    {
      "before": ["<leader>", "t", "e"],
      "commands": ["workbench.action.terminal.openNativeConsole"]
    },
    {
      "before": ["<leader>", "t", "j"],
      "commands": ["workbench.action.terminal.focusNext"]
    },
    {
      "before": ["<leader>", "t", "k"],
      "commands": ["workbench.action.terminal.focusPrevious"]
    },
    {
      "before": ["<leader>", "t", "d"],
      "commands": ["workbench.action.terminal.kill"]
    },
    {
      "before": ["g", "l"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["g", "L"],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["<S-y>"],
      "after": ["y", "$"]
    },
    {
      "before": ["<leader>", "<S-y>"],
      "after": ["\"", "*", "y", "$"]
    },
    {
      "before": ["<leader>", "n"],
      "commands": [":nohl"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [],
  "vim.insertModeKeyBindings": [
    {
      "before": ["ø"],
      "after": ["<ESC>", "o"]
    },
    {
      "before": ["Ø"],
      "after": ["<ESC>", "O"]
    },
    {
      "before": ["ˆ"],
      "after": ["<ESC>", "i"]
    },
    {
      "before": ["π"],
      "after": ["<ESC>", "p"]
    },
    {
      "before": ["∏"],
      "after": ["<ESC>", "P"]
    },
    {
      "before": ["∂"],
      "after": ["<ESC>", "d"]
    }
  ],
  "vim.insertModeKeyBindingsNonRecursive": [],
  "vim.visualModeKeyBindings": [
    {
      "before": ["<leader>", "l"],
      "commands": ["turboConsoleLog.displayLogMessage"]
    },
    {
      "before": ["<leader>", "w", "r"],
      "commands": ["workbench.action.files.save"],
      "silent": true
    },
    {
      "before": ["<leader>", "w", "a"],
      "commands": ["workbench.action.files.saveFiles"],
      "silent": true
    },
    {
      "before": ["<leader>", "f", "m"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "l", "l"],
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.view.explorer"]
    },
    {
      "before": ["<leader>", "b"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    {
      "before": ["g", "t"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["g", "T"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["<leader>", "t", "m"],
      "commands": ["editor.action.toggleMinimap"]
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "t", "t"],
      "commands": ["terminal.focus"]
    },
    {
      "before": ["<leader>", "t", "n"],
      "commands": ["workbench.action.terminal.new"]
    },
    {
      "before": ["<leader>", "t", "e"],
      "commands": ["workbench.action.terminal.openNativeConsole"]
    },
    {
      "before": ["<leader>", "t", "j"],
      "commands": ["workbench.action.terminal.focusNext"]
    },
    {
      "before": ["<leader>", "t", "k"],
      "commands": ["workbench.action.terminal.focusPrevious"]
    },
    {
      "before": ["<leader>", "t", "d"],
      "commands": ["workbench.action.terminal.kill"]
    },
    {
      "before": ["g", "l"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["g", "L"],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["<leader>", "y"],
      "after": ["\"", "*", "y"]
    },
    {
      "before": ["<leader>", "<S-y>"],
      "after": ["\"", "*", "Y"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [],

  "editor.tokenColorCustomizations": {
    "[Material Theme Darker High Contrast]": {
      "comments": "#888",
      "textMateRules": [
        {
          "scope": [
            "comment",
            "string.quoted.docstring.multi.python",
            "punctuation.definition.comment.python"
          ],
          "settings": {
            "foreground": "#888"
          }
        }
      ]
    }
  },

  "terminal.integrated.fontSize": 14,
  "workbench.colorCustomizations": {
    "[Default Dark+]": {
      "editor.background": "#111",
      "breadcrumb.background": "#111",
      "tab.inactiveBackground": "#222",
      "titleBar.activeBackground": "#222",
      "activityBar.background": "#222",
      "sideBar.background": "#222",
      // "statusBar.background": "#222",
      // "statusBar.noFolderBackground": "#222"
      "statusBar.background": "#4e407b",
      "statusBar.noFolderBackground": "#4e407b"
      // "statusBar.background": "#64529f",
      // "statusBar.noFolderBackground": "#64529f"
    }
  }
}
