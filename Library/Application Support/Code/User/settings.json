{
  "workbench.colorTheme": "Material Theme Darker High Contrast",
  "workbench.iconTheme": "eq-material-theme-icons",
  "workbench.list.automaticKeyboardNavigation": false,
  "editor.fontFamily": "Jetbrains Mono, SF Mono, RobotoMono Nerd Font, Operator Mono Lig, Operator Mono, Menlo, Monaco, Fira Code, sans serif",
  "editor.letterSpacing": 0.1,
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.useTabStops": true,
  "editor.cursorSurroundingLines": 5,
  "editor.lineNumbers": "relative",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "explorer.compactFolders": false,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "terminal.external.osxExec": "iTerm.app",
  "window.newWindowDimensions": "offset",
  "workbench.startupEditor": "none",

  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "typescript.suggest.includeCompletionsWithSnippetText": false,
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": false,
    "editor.tabSize": 4
  },
  "go.toolsManagement.autoUpdate": true,
  "python.pythonPath": "/Users/dav/.pyenv/versions/3.9.6/bin/python",
  "python.defaultInterpreterPath": "/Users/dav/.pyenv/versions/3.9.6/bin/python",
  "[python]": {
    "editor.defaultFormatter": null,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.useTabStops": true,
    "gitlens.codeLens.symbolScopes": ["!Module"]
  },
  "python.formatting.provider": "black",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },

  "prettier.singleQuote": true,
  "prettier.arrowParens": "avoid",
  "relativePath.excludedExtensions": [".js", ".jsx", ".ts", ".tsx"],
  "turboConsoleLog.quote": "'",
  "turboConsoleLog.logMessagePrefix": "",
  "turboConsoleLog.insertEnclosingFunction": false,
  "turboConsoleLog.includeFileNameAndLineNum": false,
  "turboConsoleLog.insertEnclosingClass": false,
  "liveServer.settings.donotShowInfoMsg": true,

  "vim.leader": ",",
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.easymotion": true,
  "vim.handleKeys": {
    "<C-w>": false
  },
  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.view.explorer"]
    },
    {
      "before": ["<leader>", "b"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "f", "m"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["<leader>", "w", "r"],
      "commands": ["workbench.action.files.save"]
    },
    {
      "before": ["<leader>", "w", "a"],
      "commands": ["workbench.action.files.saveFiles"]
    },
    {
      "before": ["<leader>", "n"],
      "commands": [":nohl"]
    },
    {
      "before": ["<C-j>"],
      "after": ["5", "j"]
    },
    {
      "before": ["<C-k>"],
      "after": ["5", "k"]
    },
    {
      "before": ["<leader>", "j"],
      "after": ["J"]
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "t", "t"],
      "commands": ["terminal.focus"]
    },
    {
      "before": ["<leader>", "t", "n"],
      "commands": ["workbench.action.terminal.new"]
    },
    {
      "before": ["<leader>", "t", "e"],
      "commands": ["workbench.action.terminal.openNativeConsole"]
    },
    {
      "before": ["<leader>", "t", "j"],
      "commands": ["workbench.action.terminal.focusNext"]
    },
    {
      "before": ["<leader>", "t", "k"],
      "commands": ["workbench.action.terminal.focusPrevious"]
    },
    {
      "before": ["<leader>", "t", "d"],
      "commands": ["workbench.action.terminal.kill"]
    }
  ],
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": ["ø"],
      "after": ["<ESC>", "o"]
    },
    {
      "before": ["Ø"],
      "after": ["<ESC>", "O"]
    },
    {
      "before": ["ˆ"],
      "after": ["<ESC>", "i"]
    },
    {
      "before": ["π"],
      "after": ["<ESC>", "p"]
    },
    {
      "before": ["∏"],
      "after": ["<ESC>", "P"]
    },
    {
      "before": ["∂"],
      "after": ["<ESC>", "d"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "w", "r"],
      "commands": ["workbench.action.files.save"]
    },
    {
      "before": ["<leader>", "w", "a"],
      "commands": ["workbench.action.files.saveFiles"]
    },
    {
      "before": ["<leader>", "f"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.view.explorer"]
    },
    {
      "before": ["<leader>", "b"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    {
      "before": ["0"],
      "after": ["^"]
    },
    {
      "before": ["^"],
      "after": ["0"]
    },
    {
      "before": ["<leader>", "l"],
      "commands": ["turboConsoleLog.displayLogMessage"]
    }
  ],

  "editor.tokenColorCustomizations": {
    "[Material Theme Darker High Contrast]": {
      "comments": "#666666",
      "textMateRules": [
        {
          "scope": ["string.quoted.docstring.multi.python"],
          "settings": {
            "foreground": "#666666"
          }
        }
      ]
    }
  },

  "terminal.integrated.fontSize": 14,
  "workbench.colorCustomizations": {
    "terminal.background": "#000000",
    "terminal.foreground": "#D0D0D0",
    "terminalCursor.background": "#D0D0D0",
    "terminalCursor.foreground": "#D0D0D0",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiBlue": "#0E5A94",
    "terminal.ansiBrightBlack": "#505050",
    "terminal.ansiBrightBlue": "#0E5A94",
    "terminal.ansiBrightCyan": "#00AABB",
    "terminal.ansiBrightGreen": "#37B349",
    "terminal.ansiBrightMagenta": "#B31E8D",
    "terminal.ansiBrightRed": "#EB008A",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminal.ansiBrightYellow": "#F8CA12",
    "terminal.ansiCyan": "#00AABB",
    "terminal.ansiGreen": "#37B349",
    "terminal.ansiMagenta": "#B31E8D",
    "terminal.ansiRed": "#EB008A",
    "terminal.ansiWhite": "#D0D0D0",
    "terminal.ansiYellow": "#F8CA12"
  }
}
