{
  "Print Fancy": {
    "prefix": "prn",
    "body": ["print('~ $2:', $1)"],
    // "body": ["print('~ ${2/(.*)/$1/}:', $1)"],
    "description": "Type seperate message."
  },
  "Print Fancy Uppercase": {
    "prefix": "pru",
    "body": ["print('~ ${2/(.*)/${1:/upcase}/}:', $1)"],
    "description": "Type separate message with message formatted in uppercase."
  },
  "Print Quick": {
    "prefix": "prq",
    "body": ["print('~ $1:', $1)"],
    "description": "Type once."
  }
}
