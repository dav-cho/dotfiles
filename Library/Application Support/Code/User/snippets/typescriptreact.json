{
  "Export Arrow Function Component": {
    "prefix": "eafc",
    "body": [
      "export const ${1:functionName} = ($2) => {",
      "\treturn (",
      "\t\t<>",
      "\t\t\t($1 Component)",
      "\t\t</>",
      "\t);",
      "};"
    ],
    "description": "Export Arrow Function Component"
  },
  "Export Default Arrow Function Component": {
    "prefix": "edafc",
    "body": [
      "const ${1:functionName} = ($2) => {",
      "\treturn (",
      "\t\t<>",
      "\t\t\t($1 Component)",
      "\t\t</>",
      "\t);",
      "};\n",
      "export default $1;"
    ],
    "description": "Export Default Arrow Function Component"
  },
  "Export Named Function Component": {
    "prefix": "enfc",
    "body": [
      "export function ${1:functionName}($2) {",
      "\treturn (",
      "\t\t<>",
      "\t\t\t($1 Component)",
      "\t\t</>",
      "\t);",
      "};"
    ],
    "description": "Exported Named Function Component"
  },
  "Export Default Named Function Component": {
    "prefix": "ednfc",
    "body": [
      "function ${1:functionName}($2) {",
      "\treturn (",
      "\t\t<>",
      "\t\t\t($1 Component)",
      "\t\t</>",
      "\t);",
      "};\n",
      "export default $1;"
    ],
    "description": "Exported Default Named Function Component"
  },
  "useState": {
    "prefix": "uscon",
    "body": ["const [${1}, set${1/(.*)/${1:/capitalize}/}] = useState($2);"],
    "description": "useState with const declaration"
  },
  "useEffect": {
    "prefix": "ue",
    "body": ["useEffect(() => {", "\t$1", "}, []);"],
    "description": "Base useEffect Skeleton"
  },
  "useEffect Console Log": {
    "prefix": "uecon",
    "body": ["useEffect(() => {", "\tconsole.log('~ $1', $1);", "}, [$1]);"],
    "description": "useEffect Console Log"
  }
}
