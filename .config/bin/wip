#!/bin/zsh

projects_root="$HOME/code/projects/"
projects_dirs=`ls -d $HOME/code/projects/*/ | xargs -0 dirname | uniq -u`
projects=${projects_dirs//$HOME\/code\/projects\//''}
projects=${projects//\//''}

wip_root="$HOME/code/projects/wip/"
wip_dirs=`ls -d $HOME/code/projects/wip/*/ | xargs -0 dirname | uniq -u`
wip=${wip_dirs//$HOME\/code\/projects\/wip\//''}
wip=${wip//\//''}

selected=`printf "$wip\n$projects" | fzf`

if echo $projects | grep -qs $selected; then
  cd `echo $projects_root$selected`
else
  cd `echo $wip_root$selected`
fi

$SHELL
