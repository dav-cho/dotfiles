            "modifiers": {
              "mandatory": ["shift"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde",
              "modifiers": ["shift"]
            }
          ]
        }
      ]
    },
    {
      "description": "space+enter simultaneous fn active",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "simultaneous": [
              {
                "key_code": "spacebar"
              },
              {
                "key_code": "return_or_enter"
              }
            ],
            "simultaneous_options": {
              "key_down_order": "insensitive"
            },
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "space_enter_fn_simultaneous",
                "value": 1
              }
            }
          ],
          "to_if_alone": [
            {
              "key_code": "spacebar"
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "space_enter_fn_simultaneous",
                "value": 0
              }
            }
          ]
        }
      ]
    },
