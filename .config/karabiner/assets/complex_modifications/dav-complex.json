{
  "title": "dav complex modifications",
  "rules": [
    {
      "description": "control mod-tap escape",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "control",
              "lazy": true
            }
          ],
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 250
          }
        }
      ]
    },
    {
      "description": "right shift mod-tap up",
      "manipulators": [
